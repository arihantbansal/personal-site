{
	"$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
	"plugins": ["typescript", "react", "jsx-a11y"],
	"categories": {
		"correctness": "error",
		"suspicious": "warn",
		"perf": "warn"
	},
	"rules": {
		"react/react-in-jsx-scope": "off"
	},
	"ignorePatterns": [".next", "node_modules", "out"]
}
