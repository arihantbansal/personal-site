{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"arrowParens": "always",
	"bracketSpacing": true,
	"bracketSameLine": true,
	"printWidth": 100,
	"semi": true,
	"singleQuote": false,
	"tabWidth": 2,
	"trailingComma": "all",
	"useTabs": true,
	"sortTailwindcss": {},
	"sortPackageJson": false,
	"ignorePatterns": ["node_modules", ".next", "build", "out", ".vscode"]
}
